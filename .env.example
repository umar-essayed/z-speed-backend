# ============================================
# Z-SPEED Backend - Environment Variables
# ============================================

# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:zspeed123456@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# JWT Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (BullMQ + Caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# CyberSource Payment Gateway
CYBERSOURCE_MERCHANT_ID=
CYBERSOURCE_API_KEY=
CYBERSOURCE_API_SECRET=
CYBERSOURCE_SECRET_KEY=
CYBERSOURCE_BASE_URL=https://apitest.cybersource.com

# AWS S3 (File Uploads)
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
