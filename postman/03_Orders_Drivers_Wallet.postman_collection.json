          "response": [{"name":"201 Paid from Wallet","status":"Created","code":201,"header":[{"key":"Content-Type","value":"application/json"}],"body":"{\n  \"id\": \"order-uuid\",\n  \"paymentMethod\": \"WALLET\",\n  \"paymentState\": \"PAID\",\n  \"total\": 198.58\n}"},{"name":"400 Insufficient Balance","status":"Bad Request","code":400,"header":[{"key":"Content-Type","value":"application/json"}],"body":"{\n  \"statusCode\": 400,\n  \"message\": \"Insufficient wallet balance\"\n}"}]
