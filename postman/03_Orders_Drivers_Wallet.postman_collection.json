          "response": [{"name":"201 Order Created (CASH)","status":"Created","code":201,"header":[{"key":"Content-Type","value":"application/json"}],"body":"{\n  \"id\": \"order-uuid\",\n  \"customerId\": \"user-uuid\",\n  \"restaurantId\": \"rest-uuid\",\n  \"driverId\": null,\n  \"status\": \"PENDING\",\n  \"subtotal\": 179.98,\n  \"deliveryFee\": 15.0,\n  \"serviceFee\": 3.6,\n  \"tax\": 0.0,\n  \"discount\": 0.0,\n  \"total\": 198.58,\n  \"paymentMethod\": \"CASH\",\n  \"paymentState\": \"PENDING\",\n  \"deliveryAddress\": \"15 Tahrir St, Cairo\",\n  \"deliveryLat\": 30.0444,\n  \"deliveryLng\": 31.2357,\n  \"customerNote\": \"Please ring the bell\",\n  \"createdAt\": \"2025-01-01T00:00:00.000Z\",\n  \"items\": [\n    {\n      \"id\": \"oi-uuid\",\n      \"foodItemId\": \"food-uuid\",\n      \"quantity\": 2,\n      \"unitPrice\": 89.99,\n      \"selectedAddons\": [{\"name\":\"Extra sauce\",\"price\":5}],\n      \"specialNote\": \"No spicy\"\n    }\n  ]\n}"}]
        },
