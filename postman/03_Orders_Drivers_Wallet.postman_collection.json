          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{access_token}}"},{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{base_url}}/orders/checkout","host":["{{base_url}}"],"path":["orders","checkout"]},
            "body": {"mode":"raw","raw":"{\n  \"restaurantId\": \"{{restaurant_id}}\",\n  \"deliveryAddressId\": \"ADDRESS_UUID\",\n  \"paymentMethod\": \"CASH\",\n  \"promoCode\": null,\n  \"customerNote\": \"Please ring the bell\"\n}","options":{"raw":{"language":"json"}}}
